{
  "name": "yunoball",
  "version": "0.0.0",
  "private": true,
  "description": "Natural-language search over NFL historical data \u2014 StatMuse, but more advanced.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @yunoball/web dev",
    "dev:server": "pnpm --filter @yunoball/server dev",
    "ingest:nfl": "pnpm --filter @yunoball/server ingest",
    "db:migrate": "pnpm --filter @yunoball/server db:migrate",
    "build:web": "pnpm --filter @yunoball/web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "e2e": "pnpm --filter @yunoball/web e2e"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
