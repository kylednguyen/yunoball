{
  "name": "yunoball",
  "version": "0.0.0",
  "private": true,
  "description": "Natural-language search over NFL historical data — StatMuse, but more advanced.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @yunoball/web dev",
    "dev:server": "pnpm --filter @yunoball/server dev",
    "ingest:nfl": "pnpm --filter @yunoball/server ingest",
    "db:migrate": "pnpm --filter @yunoball/server db:migrate",
    "build:web": "pnpm --filter @yunoball/web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "e2e": "pnpm --filter @yunoball/web e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@next/eslint-plugin-next": "^15.5.20",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0"
  }
}
