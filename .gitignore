# dependencies
node_modules/
.pnpm-store/

# builds
dist/
.next/
out/
*.tsbuildinfo

# env — never commit real env files; only the placeholder template
.env
.env.*
!.env.example

# python
__pycache__/
*.py[cod]
.venv/
venv/
.python-version
*.egg-info/

# data artifacts (raw downloads / parquet caches)
packages/ingest/data/
*.parquet

# demo database (regenerated on startup)
*.db

# turbo
.turbo/

# local docker override (machine-specific port remap)
docker-compose.override.yml

# next.js generated
next-env.d.ts

# logs / os
*.log
.DS_Store

# local tooling / editor / agent state
.claude/
.vercel
.mcp.json

# keys & certs — never commit
*.pem
*.key
*.p12
*.pfx
