{
  "name": "@yunoball/server",
  "version": "0.0.0",
  "private": true,
  "description": "YunoBall Express backend — REST APIs + NFLverse ingestion over the Postgres warehouse.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts",
    "ingest": "tsx src/ingest/cli.ts",
    "fetch-espn-ids": "tsx src/cli/fetchEspnIds.ts"
  },
  "dependencies": {
    "@yunoball/types": "workspace:*",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "pg": "^8.16.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
