{
  "_doc": "The query language: 50 common questions across every format the rule-based parser (query/parse_rules.py) understands. Each entry pins the expected intent + stat; tests/test_platform_routers.py asserts all of them parse. GET /api/search/examples samples from here for the home-page chips.",
  "formats": [
    {
      "intent": "leaders",
      "template": "Who <threw / rushed for / caught / had> the most <stat> in <year>?",
      "also": "Most <stat> in <year> | Who led the league in <stat> in <year>?"
    },
    {
      "intent": "leaders",
      "template": "Most <stat> in a season",
      "note": "No year means the best single-season marks since 1999."
    },
    {
      "intent": "player_total",
      "template": "<Player> career <stat>",
      "also": "<Player> <stat> (no year reads as career)"
    },
    {
      "intent": "player_total",
      "template": "<Player> <stat> in <year>",
      "also": "How many <stat> did <Player> <throw / have / rush for> in <year>?"
    },
    {
      "intent": "single_game",
      "template": "Most <stat> in a single game",
      "also": "Most <stat> in one game"
    },
    {
      "intent": "compare",
      "template": "<Player A> versus <Player B>",
      "also": "<Player A> vs <Player B> <stat>; scope modifiers apply to both sides",
      "note": "No stat compares the full stat line, narrated on the matchup's primary real stat (QB passing, RB rushing, WR/TE receiving)."
    },
    {
      "modifier": "postseason",
      "template": "\u2026 in the playoffs / postseason / post season",
      "note": "Works with every intent; switches season_type REG -> POST."
    },
    {
      "modifier": "first_n",
      "template": "\u2026 first <N> games",
      "note": "First N games in career order (digits or one through ten); combines with postseason."
    }
  ],
