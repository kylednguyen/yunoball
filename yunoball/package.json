{
  "name": "yunoball",
  "version": "0.0.0",
  "private": true,
  "description": "Natural-language search over NFL historical data — StatMuse, but more advanced.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @yunoball/web dev",
    "build:web": "pnpm --filter @yunoball/web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
