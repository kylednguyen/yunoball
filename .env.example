# ---- Database (Postgres) ----
# Local Docker (docker-compose) default. If host port 5432 is taken, drop a
# docker-compose.override.yml remapping it (e.g. "5433:5432") and change the
# port below to match.
DATABASE_URL="postgresql://yunoball:yunoball@localhost:5432/yunoball"
# Optional least-privilege, read-only role used for engine-executed SQL and
# API reads; falls back to DATABASE_URL when unset.
READONLY_DATABASE_URL=""

# ---- Supabase (hosted) alternative — swap the URLs above for these ----
# Use the SESSION pooler (port 5432) for the persistent API server — NOT the
# transaction pooler (6543), which is for serverless. SSL is auto-enabled for
# non-localhost hosts. Find both under Supabase → Project → Connect.
# DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Database TLS + pool tuning (hosted only) ----
# For a hosted DB, supply the provider CA to get VERIFIED TLS. Without it the
# connection is encrypted but unverified (MITM-able) and the server logs a
# warning. Provide the PEM inline or as a file path (Supabase → Connect → SSL).
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# DATABASE_CA_CERT_FILE="/etc/secrets/supabase-ca.pem"
# Pool size per pool and query-safety limits (ms). Defaults shown.
# DB_POOL_MAX=10
# DB_CONNECTION_TIMEOUT_MS=10000
# DB_STATEMENT_TIMEOUT_MS=15000          # user-facing (read-only) query cap
# DB_WRITE_STATEMENT_TIMEOUT_MS=120000   # generous cap for ingest batch writes

# ---- API ----
API_PORT=4000
# Comma-separated allowed origins for CORS.
CORS_ORIGINS="http://localhost:3000"
# Trusted proxy hops in front of the API (Render/Fly terminate at one LB).
# Drives Express's req.ip so the rate limiter can't be fooled by a spoofed
# X-Forwarded-For. 0 = trust none (direct connections / local dev). Default 1.
# TRUST_PROXY_HOPS=1
# Per-IP cap on POST /api/search and /api/agent (0 disables).
RATE_LIMIT_PER_MINUTE=30
# TTL (seconds) for cached answers in answer_cache. Default 86400 (24h).
# ANSWER_CACHE_TTL_SECONDS=86400
# pino log level: fatal|error|warn|info|debug|trace|silent. Default info.
# LOG_LEVEL=info

# ---- Ingest ----
# Where nflverse CSV downloads are cached. Default ~/.cache/yunoball-ingest.
# INGEST_CACHE_DIR="~/.cache/yunoball-ingest"

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Set to "true" to unlock the /assistant page (otherwise it shows a locked
# state). Baked in at build time, so rebuild the web app after changing it.
# NEXT_PUBLIC_ASSISTANT_ENABLED=false
