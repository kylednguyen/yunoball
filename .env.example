# ---- Database ----
# Local docker-compose Postgres (simplest for testing the real path):
DATABASE_URL="postgresql://yunoball:yunoball@localhost:5432/yunoball"
DIRECT_DATABASE_URL="postgresql://yunoball:yunoball@localhost:5432/yunoball"
# Least-privilege, read-only role that executes LLM-generated SQL.
# (Falls back to DATABASE_URL if unset — fine for local; use a real RO role in prod.)
READONLY_DATABASE_URL=""

# Supabase alternative:
# DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Cache ----
REDIS_URL="redis://localhost:6379/0"

# ---- LLM (OpenAI: generation + embeddings) ----
OPENAI_API_KEY=""

# ---- API ----
API_PORT=4000

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
