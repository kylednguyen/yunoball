# ---- Database (Postgres + pgvector) ----
# Local Docker (docker-compose) defaults. If host port 5432 is free, use 5432;
# the bundled override maps the container to 5433 when 5432 is taken.
DATABASE_URL="postgresql://yunoball:yunoball@localhost:5433/yunoball"
# Direct connection — used for migrations / ingestion.
DIRECT_DATABASE_URL="postgresql://yunoball:yunoball@localhost:5433/yunoball"
# Least-privilege, read-only role that executes LLM-generated SQL
# (created by `yunoball-provision-readonly`).
READONLY_DATABASE_URL="postgresql://yunoball_ro:yunoball_ro@localhost:5433/yunoball"

# ---- Supabase (hosted) alternative — swap the three URLs above for these ----
# DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# READONLY_DATABASE_URL=""

# ---- Cache ----
REDIS_URL="redis://localhost:6379/0"

# ---- LLM (OpenAI-compatible: generation + embeddings) ----
# Option A — OpenAI:
OPENAI_API_KEY=""
# SQL_MODEL="gpt-4o"
# NARRATE_MODEL="gpt-4o-mini"
# EMBEDDINGS_ENABLED="true"
#
# Option B — local Ollama (OpenAI-compatible API; key is ignored locally):
# LLM_BASE_URL="http://localhost:11434/v1"
# OPENAI_API_KEY="ollama"
# SQL_MODEL="llama3.1:8b"
# NARRATE_MODEL="llama3.1:8b"
# EMBEDDINGS_ENABLED="false"   # Ollama embed models aren't 1536-dim; trgm/keyword fallback is used

# ---- API ----
API_PORT=4000

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
